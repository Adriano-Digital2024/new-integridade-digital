---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Inscrição Confirmada | Integridade Digital';
const description = 'Sua inscrição foi confirmada com sucesso. Veja os próximos passos para começar.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <div class="w-20 h-20 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-4xl text-white">&#10003;</span>
          </div>
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6">Inscrição <span class="text-blue-600">Confirmada!</span></h1>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Obrigado por se inscrever. Enviamos um email com todas as instruções para você começar.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Próximos <span class="text-blue-600">Passos</span></h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">1</span>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg mb-1">Verifique seu Email</h3>
                <p class="text-gray-600">Acesse a caixa de entrada e confirme sua inscrição clicando no link que enviamos.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">2</span>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg mb-1">Acesse o Conteúdo</h3>
                <p class="text-gray-600">Entre na área de membros e comece a acessar todo o material disponível.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">3</span>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg mb-1">Entre na Comunidade</h3>
                <p class="text-gray-600">Participe do nosso grupo exclusivo no WhatsApp e conecte-se com outros experts.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">4</span>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 text-lg mb-1">Comece a Implementar</h3>
                <p class="text-gray-600">Siga o passo a passo e comece a implementar as estratégias de automação e IA.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-6">
          <h2 class="text-3xl lg:text-5xl font-bold">Tem Alguma Dúvida?</h2>
          <p class="text-xl opacity-90">Estamos aqui para ajudar você em cada etapa.</p>
          <a href="/contato" class="inline-flex items-center bg-white text-gray-900 hover:bg-gray-100 font-bold px-8 py-4 rounded-full text-lg">
            Fale Conosco
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

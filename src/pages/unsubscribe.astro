---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Descadastrar Email | Integridade Digital';
const description = 'Página de descadastro de email da Integridade Digital.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6">Descadastrar <span class="text-blue-600">Email</span></h1>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Sentiremos sua falta! Confirme seu descadastro para não receber mais nossos emails.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-lg mx-auto text-center">
          <form class="space-y-6" action="#" method="POST">
            <div>
              <label for="email" class="block text-lg font-medium text-gray-900 mb-2">Seu email</label>
              <input type="email" id="email" name="email" placeholder="seu@email.com" class="w-full px-6 py-4 rounded-full border-2 border-gray-200 text-lg text-center" required />
            </div>
            <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Desejo Descadastrar
            </button>
          </form>
          <p class="text-gray-500 mt-8">Você pode se cadastrar novamente a qualquer momento através do nosso site.</p>
          <a href="/" class="inline-block mt-4 text-blue-600 font-semibold hover:underline">Voltar ao site</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

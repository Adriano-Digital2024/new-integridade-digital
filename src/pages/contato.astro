---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contato | Integridade Digital';
const description = 'Entre em contato com a Integridade Digital. Consultoria em automação, IA e funis de vendas.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-sky via-cloud to-sky">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-ink mb-6">Entre em <span class="text-navy">Contato</span></h1>
          <p class="text-xl text-ink/70 leading-relaxed mb-8">
            Pronto para transformar seu negócio com automação e inteligência artificial? 
            Nossa equipe está aqui para ajudar você a alcançar resultados extraordinários.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="https://api.whatsapp.com/send/?phone=12133942928&text&type=phone_number&text=Adriano%2C+estou+no+site+da+Integridade+Digital%2C+voc%C3%AA+pode+me+ajudar+a+criar+meu+funil+de+vendas+com+I.A.+de+forma+escal%C3%A1vel+para+meu+projeto%3F" target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-orange hover:bg-orange-deep text-cloud font-semibold px-6 py-3 rounded-full transition-colors">
              WhatsApp
            </a>
            <a href="mailto:contato@integridadedm.com" class="inline-flex items-center bg-navy hover:bg-navy-deep text-cloud font-semibold px-6 py-3 rounded-full transition-colors">
              Enviar Email
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Informações de <span class="text-navy">Contato</span></h2>
          <p class="text-xl text-ink/70 max-w-3xl mx-auto">Escolha a melhor forma de entrar em contato conosco.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <div class="w-16 h-16 bg-navy rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-cloud">&#9993;</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-2">Email</h3>
            <p class="text-lg font-medium text-navy mb-2">contato@integridadedm.com</p>
            <p class="text-sm text-ink/70">Resposta em até 24 horas</p>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <div class="w-16 h-16 bg-navy rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-cloud">&#9742;</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-2">WhatsApp</h3>
            <p class="text-lg font-medium text-navy mb-2">+55 (11) 99999-9999</p>
            <p class="text-sm text-ink/70">Atendimento comercial</p>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <div class="w-16 h-16 bg-navy rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-cloud">&#9906;</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-2">Localização</h3>
            <p class="text-lg font-medium text-navy mb-2">São Paulo, SP - Brasil</p>
            <p class="text-sm text-ink/70">Atendimento presencial e online</p>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <div class="w-16 h-16 bg-navy rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-cloud">&#128339;</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-2">Horário</h3>
            <p class="text-lg font-medium text-navy mb-2">Seg - Sex: 9h às 18h</p>
            <p class="text-sm text-ink/70">Fuso horário: GMT-3</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-navy to-orange-deep text-cloud">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl lg:text-5xl font-bold">Vamos Conversar Sobre Seu Projeto?</h2>
          <p class="text-xl opacity-90 max-w-3xl mx-auto">Entre em contato conosco hoje mesmo e descubra como podemos ajudar você a transformar seu negócio com automação e IA.</p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="https://api.whatsapp.com/send/?phone=12133942928&text&type=phone_number&text=Adriano%2C+estou+no+site+da+Integridade+Digital%2C+voc%C3%AA+pode+me+ajudar+a+criar+meu+funil+de+vendas+com+I.A.+de+forma+escal%C3%A1vel+para+meu+projeto%3F" target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-orange hover:bg-orange-deep text-cloud font-bold px-8 py-4 rounded-full text-lg">
              Falar no WhatsApp
            </a>
            <a href="mailto:contato@integridadedm.com" class="inline-flex items-center bg-cloud text-ink hover:bg-paper font-bold px-8 py-4 rounded-full text-lg">
              Enviar Email
            </a>
          </div>
          <p class="text-sm opacity-80">Resposta garantida em até 24 horas</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Clube Multiplicadores de Talentos | Integridade Digital';
const description = 'Clube exclusivo para multiplicadores de talentos. Transforme seu conhecimento em resultados com IA e automação.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6">
            Clube <span class="text-blue-600">Multiplicadores</span> de Talentos
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Um clube exclusivo para profissionais que querem multiplicar seu impacto e resultados com automação, inteligência artificial e estratégias de alto nível.
          </p>
          <a href="#inscrever" class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-full text-lg transition-colors">
            Quero Participar
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">Benefícios do <span class="text-blue-600">Clube</span></h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Conteúdo Exclusivo</h3>
            <p class="text-gray-600">Acesso a materiais, cursos e treinamentos exclusivos para membros.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Networking</h3>
            <p class="text-gray-600">Conexão com profissionais de alto nível e potenciais parceiros de negócio.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Mentorias ao Vivo</h3>
            <p class="text-gray-600">Sessões mensais com especialistas em automação, IA e marketing digital.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Ferramentas Premium</h3>
            <p class="text-gray-600">Acesso a ferramentas e templates exclusivos para acelerar seus resultados.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Comunidade VIP</h3>
            <p class="text-gray-600">Grupo fechado no WhatsApp e Discord para troca de experiências.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Suporte Prioritário</h3>
            <p class="text-gray-600">Atendimento personalizado e prioritário com nossa equipe de especialistas.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">Para Quem é o <span class="text-blue-600">Clube</span></h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl shadow-lg">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Mentores e Coaches</h3>
              <p class="text-gray-600">Que querem escalar seus programas com automação.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl shadow-lg">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Infoprodutores</h3>
              <p class="text-gray-600">Que buscam sistemas de vendas automatizados.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl shadow-lg">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Especialistas Digitais</h3>
              <p class="text-gray-600">Que querem multiplicar seu impacto com IA.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-white rounded-xl shadow-lg">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Empreendedores</h3>
              <p class="text-gray-600">Que desejam automatizar processos e escalar.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="inscrever" class="py-24 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl lg:text-5xl font-bold">Faça Parte do Clube</h2>
          <p class="text-xl opacity-90">Junte-se aos multiplicadores e transforme seu conhecimento em resultados extraordinários.</p>
          <a href="https://api.whatsapp.com/send/?phone=12133942928&text=Quero+saber+mais+sobre+o+Clube+Multiplicadores+de+Talentos" target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-full text-lg">
            Quero Participar
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

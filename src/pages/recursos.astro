---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Recursos & Ferramentas | Integridade Digital';
const description = 'Ferramentas e recursos gratuitos para automatizar seu negócio: ManyChat, Mautic, Supabase, Make, Typeform, Hotjar e mais.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-sky via-cloud to-sky">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-ink mb-6">Recursos & <span class="text-navy">Ferramentas</span></h1>
          <p class="text-xl text-ink/70 leading-relaxed mb-8">
            Tudo que você precisa para criar sistemas automatizados de vendas e marketing digital.
          </p>
        </div>
      </div>
    </section>

    <section class="py-24 bg-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Ferramentas Que <span class="text-navy">Utilizamos</span></h2>
          <p class="text-xl text-ink/70 max-w-3xl mx-auto">Tecnologias de ponta para automatizar e escalar seu negócio.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">ManyChat</h3>
            <p class="text-ink/70">Automação de chatbots para Facebook Messenger e Instagram com integração de IA.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">Mautic</h3>
            <p class="text-ink/70">Plataforma de automação de marketing open source para nutrir leads e disparar campanhas.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">Supabase</h3>
            <p class="text-ink/70">Banco de dados e backend escalável para aplicações modernas com autenticação integrada.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">Make</h3>
            <p class="text-ink/70">Plataforma de automação visual para conectar aplicativos e criar workflows inteligentes.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">Typeform</h3>
            <p class="text-ink/70">Formulários interativos e quizzes para capturar leads qualificados com alta taxa de conversão.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl text-center">
            <h3 class="text-xl font-bold text-ink mb-2">Hotjar</h3>
            <p class="text-ink/70">Analytics comportamental com mapas de calor e gravações para otimizar conversões.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-sky via-cloud to-sky">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Recursos <span class="text-navy">Gratuitos</span></h2>
          <p class="text-xl text-ink/70 max-w-3xl mx-auto">Materiais para baixar e começar hoje mesmo.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <h3 class="text-lg font-bold text-ink mb-3">Checklist Funil de Vendas</h3>
            <p class="text-ink/70 mb-4">Passo a passo completo para criar seu funil de vendas do zero.</p>
            <a href="#" class="text-navy font-semibold hover:underline">Baixar PDF</a>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <h3 class="text-lg font-bold text-ink mb-3">Templates Email</h3>
            <p class="text-ink/70 mb-4">Modelos prontos de emails para nutrir leads e aumentar vendas.</p>
            <a href="#" class="text-navy font-semibold hover:underline">Baixar Templates</a>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <h3 class="text-lg font-bold text-ink mb-3">Scripts Chatbots</h3>
            <p class="text-ink/70 mb-4">Scripts prontos de chatbots com IA para converter mais.</p>
            <a href="#" class="text-navy font-semibold hover:underline">Baixar Scripts</a>
          </div>
          <div class="bg-cloud p-8 rounded-xl shadow-lg text-center">
            <h3 class="text-lg font-bold text-ink mb-3">Planilha ROI</h3>
            <p class="text-ink/70 mb-4">Calcule o retorno sobre investimento das suas campanhas.</p>
            <a href="#" class="text-navy font-semibold hover:underline">Baixar Planilha</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

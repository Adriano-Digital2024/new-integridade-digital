---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Kit de Vendas Express com I.A. para Experts | Integridade Digital';
const description = 'Kit completo com página de vendas com I.A., treinamento Meta Ads e sistema de automação recorrente para escalar seus resultados.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6">
            Kit de Vendas Express com <span class="text-blue-600">I.A.</span> para Experts
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Acelere seus resultados com um sistema completo de vendas automatizado. Página de vendas com inteligência artificial, treinamento Meta Ads e automação recorrente.
          </p>
          <a href="#garantir" class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-full text-lg transition-colors">
            Garantir Meu Kit
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">O Que Está <span class="text-blue-600">Incluso</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-white">&#128187;</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Página de Vendas com I.A.</h3>
            <p class="text-gray-600">Página de vendas profissional com inteligência artificial integrada para aumentar conversões e gerar mais leads qualificados.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-white">&#127919;</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Treinamento Meta Ads</h3>
            <p class="text-gray-600">Treinamento completo de anúncios Meta Ads para criar campanhas de alta performance e escalar seus resultados com tráfego pago.</p>
          </div>
          <div class="p-8 bg-gray-50 rounded-xl text-center">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl text-white">&#9881;</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Sistema de Automação Recorrente</h3>
            <p class="text-gray-600">Sistema completo de automação de marketing para nutrir leads, disparar emails e manter seu funil funcionando 24 horas por dia.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold mb-4">Roadmap de 7 Dias</h2>
          <p class="text-xl opacity-90">Seu plano de ação para implementar o kit completo.</p>
        </div>
        <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="text-4xl font-bold mb-2 text-blue-200">Dia 1</p>
            <p class="opacity-90">Configuração da página de vendas com I.A.</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="text-4xl font-bold mb-2 text-blue-200">Dia 2-3</p>
            <p class="opacity-90">Treinamento Meta Ads + criação de campanhas</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="text-4xl font-bold mb-2 text-blue-200">Dia 4-5</p>
            <p class="opacity-90">Implementação da automação recorrente</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="text-4xl font-bold mb-2 text-blue-200">Dia 6-7</p>
            <p class="opacity-90">Otimização e lançamento oficial</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">Para Quem é Este <span class="text-blue-600">Kit</span></h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Infoprodutores</h3>
              <p class="text-gray-600">Que querem automatizar vendas e escalar resultados com IA.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Mentores e Coaches</h3>
              <p class="text-gray-600">Que desejam criar funis de alta conversão para seus programas.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Experts Digitais</h3>
              <p class="text-gray-600">Que buscam sistemas automatizados de vendas recorrentes.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#9654;</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Empreendedores</h3>
              <p class="text-gray-600">Que querem implementar IA nos seus processos de vendas.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="garantir" class="py-24 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl lg:text-5xl font-bold">Garanta Seu Kit Agora</h2>
          <p class="text-xl opacity-90">Transforme seu negócio com automação inteligente e comece a vender 24/7.</p>
          <a href="https://api.whatsapp.com/send/?phone=12133942928&text=Quero+garantir+meu+Kit+de+Vendas+Express+com+I.A." target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-full text-lg">
            Falar com Consultor
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

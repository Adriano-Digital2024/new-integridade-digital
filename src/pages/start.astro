---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Adriano Vieira - Links | Integridade Digital';
const description = 'Links e recursos de Adriano Vieira. Consultor especialista em automação, IA e funis de vendas.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-sky via-cloud to-sky">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-2xl mx-auto">
          <div class="w-32 h-32 bg-navy rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-4xl text-cloud font-bold">AV</span>
          </div>
          <h1 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Adriano <span class="text-navy">Vieira</span></h1>
          <p class="text-lg text-ink/70 mb-8">
            Consultor de Automação, Inteligência Artificial e Funis de Vendas. Ajudo experts a criar sistemas automatizados que vendem 24/7.
          </p>
          <div class="space-y-4">
            <a href="https://api.whatsapp.com/send/?phone=12133942928" target="_blank" rel="noopener noreferrer" class="block w-full bg-orange hover:bg-orange-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              WhatsApp
            </a>
            <a href="/manual-definitivo" class="block w-full bg-navy hover:bg-navy-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Manual Definitivo Grátis
            </a>
            <a href="/campanhas-inteligentes" class="block w-full bg-navy hover:bg-navy-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Kit de Vendas Express
            </a>
            <a href="/mentoria-privada" class="block w-full bg-orange hover:bg-orange-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Mentoria Privada
            </a>
            <a href="https://www.instagram.com/adrianovieira_ai/" target="_blank" rel="noopener noreferrer" class="block w-full bg-gradient-to-r from-orange-bright to-orange-deep hover:from-orange hover:to-orange-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Instagram
            </a>
            <a href="https://www.linkedin.com/in/adrianovieira-ai/" target="_blank" rel="noopener noreferrer" class="block w-full bg-navy-deep hover:bg-navy-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
              LinkedIn
            </a>
            <a href="mailto:contato@integridadedm.com" class="block w-full bg-cloud hover:bg-paper text-ink font-bold px-8 py-4 rounded-full text-lg transition-colors">
              Email
            </a>
          </div>
          <div class="mt-8 pt-8 border-t border-line">
            <p class="text-sm text-ink/55">&copy; 2026 Integridade Digital. Todos os direitos reservados.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

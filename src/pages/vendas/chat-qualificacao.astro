---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Chat de Qualificação com IA | Integridade Digital';
const description = 'Automatize a qualificação de leads com chat inteligente 24/7.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="mx-auto max-w-4xl px-6 py-20">
      <h1 class="text-4xl font-bold text-navy">Chat de Qualificação</h1>
      <p class="mt-4 text-lg text-gray-600">Automatize a qualificação de leads com chat inteligente 24/7.</p>
      <div class="mt-12 space-y-8">
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Triagem Automática</h2>
          <p class="mt-2 text-gray-600">O chat faz perguntas estratégicas para entender a dor e o orçamento do lead.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Pontuação de Leads</h2>
          <p class="mt-2 text-gray-600">Cada lead recebe um score baseado em engajamento e perfil.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Integração com CRM</h2>
          <p class="mt-2 text-gray-600">Os leads qualificados são enviados automaticamente para seu CRM.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Respostas Personalizadas</h2>
          <p class="mt-2 text-gray-600">IA treinada no seu tom de voz e conhecimento do seu produto.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

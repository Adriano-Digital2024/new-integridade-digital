---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Assistente de Copy com IA | Integridade Digital';
const description = 'Crie textos persuasivos em segundos com inteligência artificial.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="mx-auto max-w-4xl px-6 py-20">
      <h1 class="text-4xl font-bold text-navy">Assistente de Copy</h1>
      <p class="mt-4 text-lg text-ink/70">Crie textos persuasivos em segundos com inteligência artificial.</p>
      <div class="mt-12 space-y-8">
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Headlines</h2>
          <p class="mt-2 text-ink/70">Gere dezenas de opções de títulos com base no seu nicho e oferta.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">E-mails de Vendas</h2>
          <p class="mt-2 text-ink/70">Sequências completas de e-mail marketing com copy persuasiva.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Páginas de Venda</h2>
          <p class="mt-2 text-ink/70">Estruturas completas de landing pages otimizadas para conversão.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Anúncios</h2>
          <p class="mt-2 text-ink/70">Copies para Facebook Ads, Google Ads e LinkedIn Ads.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

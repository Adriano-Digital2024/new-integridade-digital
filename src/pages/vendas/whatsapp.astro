---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'WhatsApp com IA | Integridade Digital';
const description = 'Potencialize suas vendas no WhatsApp com automação inteligente.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="mx-auto max-w-4xl px-6 py-20">
      <h1 class="text-4xl font-bold text-navy">WhatsApp</h1>
      <p class="mt-4 text-lg text-gray-600">Potencialize suas vendas no WhatsApp com automação inteligente.</p>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">Disparo em Massa</h2>
          <p class="mt-2 text-gray-600">Envie mensagens personalizadas para milhares de contatos simultaneamente.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">Respostas Automáticas</h2>
          <p class="mt-2 text-gray-600">Responda perguntas frequentes com IA 24 horas por dia.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">CRM Integrado</h2>
          <p class="mt-2 text-gray-600">Histórico completo de conversas e dados dos clientes.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">Agendamento Inteligente</h2>
          <p class="mt-2 text-gray-600">Programe disparos no melhor horário para cada lead.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">Mídia Rica</h2>
          <p class="mt-2 text-gray-600">Envie imagens, vídeos, PDFs e áudios automatizados.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-xl font-bold text-navy">Relatórios</h2>
          <p class="mt-2 text-gray-600">Métricas de entrega, leitura, cliques e conversão.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

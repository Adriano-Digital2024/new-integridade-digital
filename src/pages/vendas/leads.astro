---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Gestão de Leads com IA | Integridade Digital';
const description = 'Organize, pontue e priorize seus leads de forma inteligente.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="mx-auto max-w-4xl px-6 py-20">
      <h1 class="text-4xl font-bold text-navy">Leads</h1>
      <p class="mt-4 text-lg text-ink/70">Organize, pontue e priorize seus leads de forma inteligente.</p>
      <div class="mt-12 space-y-8">
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Score de Prioridade</h2>
          <p class="mt-2 text-ink/70">IA analisa o comportamento e perfil para rankear seus leads.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Segmentação Avançada</h2>
          <p class="mt-2 text-ink/70">Filtre leads por origem, interesse, estágio e engajamento.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Histórico Completo</h2>
          <p class="mt-2 text-ink/70">Todas as interações registradas em linha do tempo por lead.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-cloud p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Exportação e API</h2>
          <p class="mt-2 text-ink/70">Exporte seus dados ou integre com qualquer ferramenta via API.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

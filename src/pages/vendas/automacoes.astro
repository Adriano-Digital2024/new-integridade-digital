---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Automações de Vendas com IA | Integridade Digital';
const description = 'Crie fluxos automatizados que vendem por você 24/7.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="mx-auto max-w-4xl px-6 py-20">
      <h1 class="text-4xl font-bold text-navy">Automações</h1>
      <p class="mt-4 text-lg text-gray-600">Crie fluxos automatizados que vendem por você 24/7.</p>
      <div class="mt-12 space-y-8">
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Funil de E-mail</h2>
          <p class="mt-2 text-gray-600">Sequências automatizadas de e-mail para nutrir leads até a compra.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Follow-up Inteligente</h2>
          <p class="mt-2 text-gray-600">Lembretes e reengajamento automático para leads mornos.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Integração com Pagamentos</h2>
          <p class="mt-2 text-gray-600">Dispare gatilhos automáticos baseados em ações de pagamento.</p>
        </div>
        <div class="rounded-2xl border-2 border-navy/10 bg-white p-8 shadow-pop">
          <h2 class="text-2xl font-bold text-navy">Webinars Automáticos</h2>
          <p class="mt-2 text-gray-600">Agende e gerencie webinars com lembretes e pós-evento.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = '3 Posts por 7 Dias - Transforme seu Instagram | Integridade Digital';
const description = 'Estratégia comprovada de 3 posts por 7 dias para transformar seu Instagram em uma máquina de vendas automatizada.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-gray-900 mb-6">
            3 Posts por <span class="text-blue-600">7 Dias</span>
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Transforme seu Instagram em uma máquina de vendas automatizada com nossa estratégia comprovada de conteúdo.
          </p>
          <a href="#garantir" class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-full text-lg transition-colors">
            Quero Participar
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">O Que Você Vai <span class="text-blue-600">Aprender</span></h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Estratégia de conteúdo que gera engajamento real</p>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Como criar posts que vendem sem ser chato</p>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Automação de atendimento no Direct</p>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Funil de vendas integrado ao Instagram</p>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Calendário editorial pronto de 7 dias</p>
          </div>
          <div class="flex items-start gap-4 p-6 bg-gray-50 rounded-xl">
            <span class="text-blue-600 text-2xl flex-shrink-0">&#10003;</span>
            <p class="text-lg text-gray-700">Métricas para acompanhar resultados</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-blue-50 via-white to-purple-50">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4">Como <span class="text-blue-600">Funciona</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="bg-white p-8 rounded-xl shadow-lg text-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-xl text-white font-bold">1</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Publique 3 Posts</h3>
            <p class="text-gray-600">Siga nosso calendário editorial com 3 posts estratégicos por semana.</p>
          </div>
          <div class="bg-white p-8 rounded-xl shadow-lg text-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-xl text-white font-bold">2</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Automatize</h3>
            <p class="text-gray-600">Configure chatbots e automações para atender leads no Direct.</p>
          </div>
          <div class="bg-white p-8 rounded-xl shadow-lg text-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-xl text-white font-bold">3</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Venda</h3>
            <p class="text-gray-600">Transforme seguidores em clientes com funis de vendas integrados.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="garantir" class="py-24 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl lg:text-5xl font-bold">Comece Hoje</h2>
          <p class="text-xl opacity-90">Transforme seu Instagram em 7 dias com nossa estratégia comprovada.</p>
          <a href="https://api.whatsapp.com/send/?phone=12133942928&text=Quero+saber+mais+sobre+o+m%C3%A9todo+3+Posts+por+7+Dias" target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-full text-lg">
            Quero Começar
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Mentoria Privada - Transforme seu negócio em uma máquina de vendas automatizada | Integridade Digital';
const description = 'Mentoria exclusiva com metodologia de 4 estágios para transformar seu negócio com automação, IA e funis de alto impacto.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    <section class="pt-24 lg:pt-32 pb-16 bg-gradient-to-br from-sky via-cloud to-sky">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl lg:text-6xl font-bold text-ink mb-6">
            Mentoria Privada: Transforme seu negócio em uma <span class="text-navy">máquina de vendas automatizada</span>
          </h1>
          <p class="text-xl text-ink/70 leading-relaxed mb-8">
            Metodologia exclusiva de 4 estágios para criar funis de alto impacto com inteligência artificial e automação.
          </p>
          <a href="#inscrever" class="inline-flex items-center bg-navy hover:bg-navy-deep text-cloud font-bold px-8 py-4 rounded-full text-lg transition-colors">
            Quero Ser Mentorado
          </a>
        </div>
      </div>
    </section>

    <section class="py-24 bg-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Nossa Metodologia de <span class="text-navy">4 Estágios</span></h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          <div class="p-8 bg-paper rounded-xl">
            <div class="w-12 h-12 bg-navy rounded-full flex items-center justify-center mb-4">
              <span class="text-xl text-cloud font-bold">1</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">Diagnóstico</h3>
            <p class="text-ink/70">Análise completa do seu negócio, identificando gargalos, oportunidades e pontos de alavancagem para automação.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl">
            <div class="w-12 h-12 bg-navy rounded-full flex items-center justify-center mb-4">
              <span class="text-xl text-cloud font-bold">2</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">Estratégia</h3>
            <p class="text-ink/70">Desenvolvimento de um plano personalizado com funis de vendas, integração de IA e automações inteligentes.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl">
            <div class="w-12 h-12 bg-navy rounded-full flex items-center justify-center mb-4">
              <span class="text-xl text-cloud font-bold">3</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">Implementação</h3>
            <p class="text-ink/70">Colocação da estratégia em prática com suporte direto da nossa equipe especializada em automação e IA.</p>
          </div>
          <div class="p-8 bg-paper rounded-xl">
            <div class="w-12 h-12 bg-navy rounded-full flex items-center justify-center mb-4">
              <span class="text-xl text-cloud font-bold">4</span>
            </div>
            <h3 class="text-xl font-bold text-ink mb-3">Otimização</h3>
            <p class="text-ink/70">Monitoramento contínuo, análise de métricas e ajustes para maximizar resultados e ROI.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-navy to-orange-deep text-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold mb-4">O Que Está <span class="text-sky">Incluso</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Sessões Semanais</p>
            <p class="opacity-80">Encontros exclusivos com seu mentor</p>
          </div>
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Suporte 24/7</p>
            <p class="opacity-80">Acesso direto à equipe via WhatsApp</p>
          </div>
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Funis Personalizados</p>
            <p class="opacity-80">Criação de funis sob medida para seu negócio</p>
          </div>
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Automação Completa</p>
            <p class="opacity-80">Sistemas automatizados de vendas e marketing</p>
          </div>
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Dashboard de Métricas</p>
            <p class="opacity-80">Acompanhamento em tempo real dos resultados</p>
          </div>
          <div class="bg-cloud/10 backdrop-blur-sm rounded-xl p-6 text-center">
            <p class="font-bold text-lg mb-2">Comunidade Exclusiva</p>
            <p class="opacity-80">Networking com outros mentoreados</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink mb-4">Resultados dos <span class="text-navy">Nossos Mentorados</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="p-8 bg-paper rounded-xl">
            <div class="flex text-orange-bright mb-4">
              <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
            </div>
            <p class="text-ink mb-4">"A mentoria transformou meu negócio. Em 3 meses meu faturamento triplicou com os funis automatizados."</p>
            <p class="font-bold text-ink">Ana Paula</p>
            <p class="text-sm text-ink/55">Infoprodutora</p>
          </div>
          <div class="p-8 bg-paper rounded-xl">
            <div class="flex text-orange-bright mb-4">
              <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
            </div>
            <p class="text-ink mb-4">"Metodologia incrível. Consegui automatizar 80% dos meus processos e focar no que realmente importa."</p>
            <p class="font-bold text-ink">Felipe Rocha</p>
            <p class="text-sm text-ink/55">Coach</p>
          </div>
          <div class="p-8 bg-paper rounded-xl">
            <div class="flex text-orange-bright mb-4">
              <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
            </div>
            <p class="text-ink mb-4">"Suporte excepcional e resultados reais. Recomendo para todo expert que quer escalar com IA."</p>
            <p class="font-bold text-ink">Juliana Castro</p>
            <p class="text-sm text-ink/55">Mentora Digital</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-gradient-to-br from-navy to-orange-deep text-cloud">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-5xl font-bold mb-4">Conheça Nossa <span class="text-sky">Equipe</span></h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="text-center">
            <div class="w-32 h-32 bg-cloud/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl text-cloud font-bold">AV</span>
            </div>
            <h3 class="text-xl font-bold mb-1">Adriano Vieira</h3>
            <p class="opacity-80">CEO & Fundador<br />Especialista em Automação e IA</p>
          </div>
          <div class="text-center">
            <div class="w-32 h-32 bg-cloud/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl text-cloud font-bold">SM</span>
            </div>
            <h3 class="text-xl font-bold mb-1">Sandra Magalhães</h3>
            <p class="opacity-80">Head de Marketing<br />Estratégia de Funis</p>
          </div>
          <div class="text-center">
            <div class="w-32 h-32 bg-cloud/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl text-cloud font-bold">JV</span>
            </div>
            <h3 class="text-xl font-bold mb-1">Jeferson Vasconcelos</h3>
            <p class="opacity-80">CTO<br />Automação e Integrações</p>
          </div>
        </div>
      </div>
    </section>

    <section id="inscrever" class="py-24 bg-cloud">
      <div class="container mx-auto px-4 text-center">
        <div class="max-w-4xl mx-auto space-y-8">
          <h2 class="text-3xl lg:text-5xl font-bold text-ink">Quer Ser <span class="text-navy">Mentorado?</span></h2>
          <p class="text-xl text-ink/70 max-w-3xl mx-auto">Agende uma conversa gratuita para descobrir como podemos transformar seu negócio.</p>
          <a href="https://api.whatsapp.com/send/?phone=12133942928&text=Quero+saber+mais+sobre+a+Mentoria+Privada" target="_blank" rel="noopener noreferrer" class="inline-flex items-center bg-orange hover:bg-orange-deep text-cloud font-bold px-8 py-4 rounded-full text-lg">
            Agendar Conversa
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

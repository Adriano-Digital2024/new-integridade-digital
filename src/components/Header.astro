---
import Logo from './Logo.astro';

const links = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/vendas', label: 'Vendas' },
	{ href: '/recursos', label: 'Recursos' },
	{ href: '/contato', label: 'Contato' },
];
---

<nav
	id="site-nav"
	class="sticky top-0 z-50 border-b-[3px] border-blue-600 bg-white/96 backdrop-blur-xl transition-shadow duration-250"
>
	<div class="mx-auto flex max-w-[1200px] items-center gap-8 px-8 py-4">
		<a href="/" class="text-xl font-bold text-blue-600">Integridade Digital</a>
		<div class="hidden gap-7 text-[15px] font-semibold md:flex">
			{links.map((link) => <a href={link.href} class="text-gray-600 hover:text-blue-600">{link.label}</a>)}
		</div>
		<div class="ml-auto flex items-center gap-3.5">
			<a href="/search" aria-label="Search" class="text-gray-600 hover:text-blue-600">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
					<circle cx="11" cy="11" r="7"></circle>
					<line x1="21" y1="21" x2="16.5" y2="16.5"></line>
				</svg>
			</a>
			<a
				href="/contato"
				class="rounded-full bg-blue-600 px-5 py-2.5 text-[15px] font-bold text-white transition hover:bg-blue-700"
				>Fale Conosco</a
			>
		</div>
	</div>
</nav>

<script>
	// スクロール時にシャドウを付ける（プロトタイプ: scrollY > 8 で 0 6px 20px rgba(15,30,66,.25)）
	const nav = document.getElementById('site-nav');
	const onScroll = () => {
		if (!nav) return;
		nav.style.boxShadow = window.scrollY > 8 ? '0 6px 20px rgb(15 30 66 / 0.25)' : 'none';
	};
	window.addEventListener('scroll', onScroll, { passive: true });
	onScroll();
</script>
